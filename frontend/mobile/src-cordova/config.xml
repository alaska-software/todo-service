<?xml version='1.0' encoding='utf-8'?>
<widget id="com.alaskasoftware.mobileapp.mytodoeditor" version="1.2.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>MyTodoEditor</name>
    <description>Editing todo items</description>
    <author email="info@alaska-software.com" href="https://www.alaska-software.com">
        Alaska Software Inc.
    </author>
    <content src="index.html" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-navigation href="about:*" />
    <platform name="android">
        <icon src="../src/assets/databear.png" />
    </platform>
    <preference name="Scheme" value="http" />
</widget>
